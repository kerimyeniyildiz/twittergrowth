# === RapidAPI (Tweet collection) ===
RAPIDAPI_KEY=your_rapidapi_key
RAPIDAPI_HOST=twitter-api45.p.rapidapi.com

# === Replicate (LLM provider) ===
REPLICATE_API_TOKEN=your_replicate_api_token
MODEL_GPT_MINI=openai/gpt-5-mini
MODEL_GEMINI_FLASH=google/gemini-3-flash
MODEL_GEMINI_PRO=google/gemini-3.1-pro

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ADMIN_ID=your_telegram_user_id

# === X / Twitter API (posting) ===
X_API_KEY=your_x_api_key
X_API_SECRET=your_x_api_secret
X_ACCESS_TOKEN=your_x_access_token
X_ACCESS_SECRET=your_x_access_secret

# === App Config ===
DRY_RUN=false
TIMEZONE=Europe/Istanbul
NIGHT_MODE=false
NIGHT_START=23:00
NIGHT_END=08:00
AUTO_SEND=false
MAX_TWEETS_PER_POLL=10
